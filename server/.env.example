# Copie este arquivo para .env e ajuste os valores antes de rodar o projeto.

NODE_ENV=development
PORT=3333

# Ao rodar via docker-compose, o host do banco é "postgres" (nome do serviço).
# Ao rodar localmente sem Docker, use "localhost".
DATABASE_URL=postgresql://novaloja:novaloja_dev_password@localhost:5432/novaloja?schema=public

REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=troque_por_um_segredo_forte_de_acesso
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque_por_um_segredo_forte_de_refresh
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origem permitida do front-end
CLIENT_URL=http://localhost:5173

# Cloudinary (upload de imagens)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pagamentos
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
# Painel MP > Suas integrações > Webhooks > Chave secreta — valida o header x-signature
# das notificações. Obrigatório em produção se MERCADOPAGO_ACCESS_TOKEN estiver definido.
MERCADOPAGO_WEBHOOK_SECRET=

# Frete
MELHOR_ENVIO_TOKEN=
